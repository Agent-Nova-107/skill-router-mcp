{
  "name": "skill-router-mcp",
  "version": "0.1.0",
  "description": "Read-only MCP server that routes AI agents to relevant installed skills",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "skill-router-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "cursor",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "keywords": [
    "mcp",
    "cursor",
    "skills",
    "agent",
    "routing"
  ],
  "author": "AgentGoyave",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agent-Nova-107/skill-router-mcp.git"
  },
  "homepage": "https://github.com/Agent-Nova-107/skill-router-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
